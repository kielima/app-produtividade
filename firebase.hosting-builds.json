{
  "hosting": {
    "site": "app-produtividade-builds",
    "public": "firebase-hosting",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.zip",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/vnd.android.package-archive"
          },
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
