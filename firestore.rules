rules_version = '2';

// =============================================================
// Security rules — app-produtividade
// Acesso restrito ao UID do dono (Kiê). Default deny em tudo.
//
// IMPORTANTE: preencher AUTHORIZED_UID após o primeiro login Google
// no PWA já deployado. Até lá, todo acesso ao Firestore é negado.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null
          && request.auth.uid == uid
          && request.auth.uid == 'AUTHORIZED_UID_PLACEHOLDER';
    }

    match /users/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // Default deny — qualquer outro path é bloqueado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
