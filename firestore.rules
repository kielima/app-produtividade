rules_version = '2';

// =============================================================
// Security rules — app-produtividade
//
// App pessoal de um usuário só, autenticado via PIN (email/password
// fixo internamente). Cada usuário autenticado acessa apenas o próprio
// caminho /users/{uid}. Default deny em tudo o mais.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSelf(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      // Doc do próprio usuário (se houver campos no nível raiz).
      allow read, write: if isSelf(uid);

      // Segredos do servidor (refresh token do Google Calendar etc.):
      // SOMENTE o Admin SDK das Functions lê/escreve. O cliente nunca acessa.
      match /private/{document=**} {
        allow read, write: if false;
      }

      // Status de conexão do calendário: flag não sensível que o cliente
      // LÊ para saber se já conectou (sincroniza a UX entre dispositivos).
      // A escrita é exclusiva das Functions (Admin SDK).
      match /calendar/{document=**} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      // Status de conexão do Google Drive (aba Leitura): mesma ideia do
      // calendar — cliente lê a flag, escrita só pelas Functions.
      match /drive/{document=**} {
        allow read: if isSelf(uid);
        allow write: if false;
      }

      // Demais dados do usuário (tasks, projects, notes, readingItems, ...):
      // acesso total ao próprio dono. As subárvores protegidas acima não
      // são alcançadas por esta regra.
      match /{collection}/{document=**} {
        allow read, write: if isSelf(uid)
          && collection != 'private'
          && collection != 'calendar'
          && collection != 'drive';
      }
    }

    // Versão publicada do app (verificador de atualização in-app). Contém só o
    // commit da última build e a URL do APK — nenhum dado pessoal —, por isso a
    // leitura é pública: o app confere atualização mesmo sem login. Só o backend
    // (Admin SDK do workflow, que ignora estas regras) escreve aqui.
    match /app/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny — qualquer outro path é bloqueado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
