# =============================================================
#  app-produtividade — .gitignore
#  Cobre: Node + Vite + Firebase + ignores específicos do projeto
# =============================================================

# -------- Node / Vite / PWA --------
node_modules/
dist/
build/
.vite/
*.tsbuildinfo
# vite-plugin-pwa generates a dev SW in dev mode
dev-dist/

# -------- Variáveis de ambiente (NUNCA commitar) --------
.env
.env.local
.env.*.local
.env.development
.env.production

# -------- Firebase (segredos e cache) --------
.firebase/
.firebaserc.local
*firebase-adminsdk*.json
serviceAccount*.json
service-account*.json
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log
pubsub-debug.log

# -------- Chaves e certificados --------
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr

# -------- Logs e caches --------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnpm-store/
.cache/

# -------- Editores e SO --------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# -------- Cobertura de testes --------
coverage/
.nyc_output/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# =============================================================
#  Ignores específicos do projeto (decisões D5-D8)
# =============================================================

# Conteúdo do vault local — fonte de dados pra migração, lida do disco;
# o app em si não depende disso e nada do "memory/" precisa estar versionado.
memory/

# Diário pessoal — íntimo
diary/

# Plugin/skill do Cowork-Claude Code, não pertence ao app
skills/

# Outputs gerados (relatórios, docx, etc.)
outputs/

# Config do Obsidian (vault local)
.obsidian/

# Lixeira do Obsidian
.trash/

# =============================================================
#  Conteúdo do sistema local (mantém funcionando em paralelo)
#  Estes ARQUIVOS DE DADOS ficam de fora do repo — pertencem ao
#  vault Obsidian local do Kiê, não ao código do app PWA.
# =============================================================

# Tarefas e projetos: fonte da verdade do dashboard local
Minhas_Tarefas.md
Tarefas_Concluidas.md
Meus_Projetos.md

# Diário, notas e listas pessoais
agenda*.md
minha_rotina*.md
watch*list*.md
PÁGINA*DE*CONQUISTAS.md
Log_Salvos.md
Prompt_Processamento_Log.md
automations.md
listas/

# Imagens de preview soltas na raiz (não bloquear PWA icons em public/)
/*.png
/*.jpg
/*.jpeg

# Configs do Obsidian Web Clipper
default-clipper.json

# CLAUDE.md local — instruções privadas pro assistente
CLAUDE.md
