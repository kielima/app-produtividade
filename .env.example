# Configuração do Firebase client (consumido pelo Vite)
# Copiar para .env.local e preencher após criar o projeto no console Firebase.
# Project settings > Your apps > Web app > SDK setup > Config

VITE_FIREBASE_API_KEY=AIzaSyBQ8FmHCzAN5IVL0ybdU0Y_MkmQiAVJ5cA
VITE_FIREBASE_AUTH_DOMAIN=app-produtividade-3ec9d.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=app-produtividade-3ec9d
VITE_FIREBASE_STORAGE_BUCKET=app-produtividade-3ec9d.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=739803156090
VITE_FIREBASE_APP_ID=1:739803156090:web:c132479563bf01163135c3

# Defina como "true" para apontar pros emuladores locais (ports 8081/9099)
VITE_USE_FIREBASE_EMULATOR=false

# OAuth 2.0 Web Client ID usado pelo Google Identity Services para abrir o
# consentimento do Google Calendar (uma vez). Google Cloud Console > APIs &
# Services > Credentials > "Web client". É o mesmo client que o Firebase Auth usa.
# O CLIENT SECRET correspondente NÃO vai aqui: ele é segredo das Cloud Functions
# (ver abaixo), pois é lá que o refresh token é trocado/guardado.
VITE_GOOGLE_OAUTH_CLIENT_ID=

# ---- Segredo das Cloud Functions (NÃO é lido pelo front/Vite) ----
# Só o CLIENT SECRET é sigiloso. O client ID é público (constante no backend).
# Configurar no Secret Manager (produção) ou functions/.secret.local (emulador).
# A chave secreta está no mesmo "Web client" do client ID acima.
#   firebase functions:secrets:set GOOGLE_OAUTH_CLIENT_SECRET

# ---- Variáveis usadas só pelo script de migração (Admin SDK, Node) ----
# Caminho pro service account JSON baixado do console Firebase.
# NUNCA commitar esse arquivo. Já coberto pelo .gitignore.
GOOGLE_APPLICATION_CREDENTIALS=/caminho/local/serviceAccount.json

# UID do dono — usado pelo script pra escrever em users/{uid}/...
MIGRATE_UID=

# Caminhos pros arquivos .md de origem (locais, fora do repo)
MIGRATE_TASKS_FILE=/caminho/local/Minhas_Tarefas.md
MIGRATE_PROJECTS_FILE=/caminho/local/Meus_Projetos.md
MIGRATE_COMPLETED_FILE=/caminho/local/Tarefas_Concluidas.md
MIGRATE_MEMORY_DIR=/caminho/local/memory
