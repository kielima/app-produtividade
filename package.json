{
  "name": "app-produtividade",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "PWA pessoal de tarefas, projetos e memória — em transição do dashboard local",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx scripts/migrate/index.ts",
    "pwa:assets": "pwa-assets-generator --preset minimal-2023 public/logo.png",
    "emulators": "firebase emulators:start",
    "deploy": "npm run build && firebase deploy --only hosting,firestore:rules,functions",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "firebase": "^10.14.1",
    "pdfjs-dist": "^4.10.38",
    "perfect-freehand": "^1.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-firebase-hooks": "^5.1.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vite-pwa/assets-generator": "^0.2.6",
    "@vitejs/plugin-react": "^4.3.4",
    "firebase-admin": "^13.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^2.1.5"
  }
}
